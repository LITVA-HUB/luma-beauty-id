# development | staging | production
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8010
PUBLIC_API_BASE_URL=http://127.0.0.1:8010
STORE_PATH=.data/luma_beauty.sqlite3
LOG_LEVEL=INFO

# Development auth is blocked automatically in production mode.
ALLOW_DEV_AUTH=true
AUTH_PROVIDER=local
AUTH_PROVIDER_URL=
AUTH_PROVIDER_API_KEY=
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

# Development/staging seed catalog. Production must use CATALOG_PROVIDER=external.
CATALOG_PROVIDER=local
CATALOG_API_BASE_URL=
CATALOG_API_TOKEN=

# Development/staging handoff. Production must use CHECKOUT_PROVIDER=external or checkout stays unavailable.
CHECKOUT_PROVIDER=development_handoff
CHECKOUT_HANDOFF_URL=
CHECKOUT_API_KEY=

# Scan/photo provider. Production must use SCAN_PROVIDER=external.
SCAN_PROVIDER=dev
SCAN_PROVIDER_URL=
SCAN_PROVIDER_API_KEY=
MAX_PHOTO_BYTES=5000000
ALLOWED_PHOTO_MIME_TYPES=image/jpeg,image/png,image/heic,image/heif

# Advisor provider. iOS never calls OpenRouter directly; only backend reads OPENROUTER_API_KEY.
ADVISOR_PROVIDER=deterministic
ADVISOR_TIMEOUT_SECONDS=18
ADVISOR_PROMPT_VERSION=luma-advisor-2026-05-rc2
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RESPONSE_FORMAT=json_schema
GEMINI_API_KEY=

# Only used for local tools or a separate web client during development/staging.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
