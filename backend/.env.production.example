APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8010
PUBLIC_API_BASE_URL=https://api.yourdomain.example
STORE_PATH=/var/lib/luma/luma_beauty.sqlite3
LOG_LEVEL=INFO
ALLOW_DEV_AUTH=false

AUTH_PROVIDER=external
AUTH_PROVIDER_URL=https://identity-provider.example
AUTH_PROVIDER_API_KEY=replace_with_secret_from_secret_manager
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

CATALOG_PROVIDER=external
CATALOG_API_BASE_URL=https://retail-catalog.example
CATALOG_API_TOKEN=replace_with_secret_from_secret_manager

CHECKOUT_PROVIDER=external
CHECKOUT_HANDOFF_URL=https://checkout.example/session
CHECKOUT_API_KEY=replace_with_secret_from_secret_manager

SCAN_PROVIDER=external
SCAN_PROVIDER_URL=https://vision-provider.example/analyze
SCAN_PROVIDER_API_KEY=replace_with_secret_from_secret_manager
MAX_PHOTO_BYTES=5000000
ALLOWED_PHOTO_MIME_TYPES=image/jpeg,image/png,image/heic,image/heif

ADVISOR_PROVIDER=openrouter
ADVISOR_TIMEOUT_SECONDS=18
ADVISOR_PROMPT_VERSION=luma-advisor-2026-05-rc2
OPENROUTER_API_KEY=replace_with_secret_from_secret_manager
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=replace_with_approved_model_slug
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RESPONSE_FORMAT=json_schema
GEMINI_API_KEY=

CORS_ALLOW_ORIGINS=
