// Settings shared by every environment. Per-environment files import this
// file and then override API_BASE_URL / APP_ENVIRONMENT / bundle id.

ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
CODE_SIGN_STYLE = Automatic
