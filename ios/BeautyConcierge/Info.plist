<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>Золотое Яблоко</string>
    <key>CFBundleName</key>
    <string>BeautyConcierge</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string></string>
    </dict>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>NSCameraUsageDescription</key>
    <string>Luma использует камеру для фото beauty-профиля при настройке. Снимок нужен для косметического подбора — это не медицинский скан и не диагностика.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Luma читает только выбранное вами фото для beauty-профиля. Снимок используется только для косметического подбора.</string>
    <key>API_BASE_URL</key>
    <string>$(API_BASE_URL)</string>
    <key>APP_ENVIRONMENT</key>
    <string>$(APP_ENVIRONMENT)</string>
    <key>PrivacyPolicyURL</key>
    <string>https://lumabeautyid.app/privacy</string>
    <key>SupportURL</key>
    <string>https://lumabeautyid.app/support</string>
    <key>AccountDeletionURL</key>
    <string>https://lumabeautyid.app/account-deletion</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Allows http only to local-network hosts (RFC1918 / .local), e.g. the
             dev backend at http://<mac-ip>:8010 reached from a physical device.
             Public traffic still requires https. -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
